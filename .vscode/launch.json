{
  "version": "0.2.0",
  "configurations": [

    // ‚îÄ‚îÄ 0. Run integration tests (shows results in VS Code Test Explorer) ‚îÄ‚îÄ‚îÄ‚îÄ
    {
      "name": "Integration Tests",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/out/test/suite/index",
        "--user-data-dir=/tmp/vscode-debuggingai-test"
      ],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "compile",
      "sourceMaps": true
    },



    // ‚îÄ‚îÄ 1. Run the extension in a real VS Code window ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // Press F5. Opens an Extension Development Host with DebuggingAI active.
    // This is how you manually test commands, gutter breakpoints, output channel.
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "compile"
    },

    // ‚îÄ‚îÄ 2. Debug the extension itself (breakpoints in extension.ts etc.) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // Same as above but you can set breakpoints in src/extension.ts,
    // src/breakpoints.ts, src/server.ts and they will hit.
    {
      "name": "Debug Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "sourceMaps": true,
      "preLaunchTask": "compile"
    },

    // ‚îÄ‚îÄ 3. Run Jest unit tests (breakpoints.test.ts etc.) ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // Lets you set breakpoints inside the test files and step through them.
    {
      "name": "Debug Jest Tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/jest",
      "args": ["--runInBand", "--testPathPattern", "${fileBasenameNoExtension}"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/out/**/*.js"]
    },

    // ‚îÄ‚îÄ 4. Debug test_app.py ‚Äî the fake Python script ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // Requires the Python VS Code extension + debugpy installed (pip install debugpy).
    // Set breakpoints via "DebuggingAI: Set Breakpoint" then launch this config.
    // This is how you prove the extension actually places breakpoints correctly.
    {
      "name": "Debug test_app.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/test_app.py",
      "console": "integratedTerminal",
      "stopOnEntry": true
    },

    // ‚îÄ‚îÄ 5. Debug test_app.js ‚Äî the fake Node.js script ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // Requires no extra tooling ‚Äî pure Node.js.
    // Set breakpoints via "DebuggingAI: Set Breakpoint" then launch this config.
    {
      "name": "Debug test_app.js",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/test_app.js",
      "console": "integratedTerminal",
      "stopOnEntry": true
    },

    // ‚îÄ‚îÄ 6. Debug test_app.ts ‚Äî the fake TypeScript script ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // Requires ts-node (already a devDependency: npm install).
    // Debugs TypeScript source directly with source maps ‚Äî no manual compile step.
    {
      "name": "Debug test_app.ts",
      "type": "node",
      "request": "launch",
      "runtimeArgs": ["-r", "ts-node/register"],
      "args": ["${workspaceFolder}/test_app.ts"],
      "console": "integratedTerminal",
      "stopOnEntry": true,
      "env": { "TS_NODE_TRANSPILE_ONLY": "true" }
    },

    // ‚îÄ‚îÄ 7. Debug the vsdbg CLI script directly ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    // Set breakpoints in bin/vsdbg, run it with args.
    {
      "name": "Debug vsdbg CLI",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/bin/vsdbg",
      "args": ["+bp", "app.py:42", "condition:{x > 100}"],
      "console": "integratedTerminal"
    }

  ]
}
